services:
  dockhand-hawser:
    image: ghcr.io/finsys/hawser:latest
    container_name: dockhand-hawser
    ports:
      - '2376:2376'
    environment:
      - TOKEN={{ dockhand_server_token }}
      - AGENT_NAME={{ dockhand_agent_name }}
      - SKIP_DF_COLLECTION=false
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - {{ dockhand_hawser_config_path }}:/data/stacks
    networks:
      - server_network
    restart: always

networks:
  server_network:
    name: {{ docker_network_name }}
    external: true